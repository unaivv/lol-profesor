{
    "name": "lol-professor-server",
    "version": "1.0.0",
    "description": "Node.js Express TypeScript server for LoL Professor",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "dev:watch": "ts-node --watch src/index.ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "axios": "^1.15.2",
        "better-sqlite3": "^12.9.0",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.0",
        "@types/express": "^4.17.0",
        "@types/node": "^20.0.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.0.0"
    },
    "keywords": [
        "league-of-legends",
        "lol",
        "riot-api",
        "express",
        "typescript"
    ],
    "author": "",
    "license": "MIT"
}
