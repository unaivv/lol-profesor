{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "LoL Professor",
    "version": "1.0.0",
    "identifier": "com.lolprofessor.desktop",
    "build": {
        "beforeDevCommand": { "script": "npm run dev", "cwd": ".." },
        "devUrl": "http://localhost:3000",
        "beforeBuildCommand": { "script": "npm run build", "cwd": ".." },
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "LoL Professor",
                "width": 1400,
                "height": 900,
                "minWidth": 1024,
                "minHeight": 700,
                "resizable": true,
                "center": true,
                "label": "main",
                "decorations": false,
                "maximized": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://*.leagueoflegends.com https://*.riotgames.com https://api.groq.com; img-src 'self' https://ddragon.leagueoflegends.com https://raw.communitydragon.org data:; style-src 'self' 'unsafe-inline'"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMjA0NTFBQUFBOERFRjUKUldUMTNxaXFHa1VndmdtOUlRV1orUkM1ZnZOZlBaV3BHajJwY2NCQmNRUWZ3M25ISEcxT2NCWXMK",
            "endpoints": [
                "https://github.com/unaivv/lol-profesor/releases/latest/download/latest.json"
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "nsis", "dmg", "app", "appimage", "deb"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "Utility",
        "shortDescription": "League of Legends statistics and match analysis",
        "longDescription": "LoL Professor is a desktop application for League of Legends players to analyze their performance, view match history, and get AI-powered insights.",
        "resources": [],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}
